{
  "name": "MailCraft",
  "description": "AI powered email response generator",
  "version": "1.0",
  "manifest_version": 3,

  "action": {
    "default_popup": "index.html",
    "default_icon": "message.png",
    "default_title": "MailCraft - AI Email Assistant"
  },

  "permissions": [
    "activeTab",
    "storage"
  ],

  "host_permissions": [
    "http://localhost:8080/*",
    "*://mail.google.com/*"
  ],

  "content_scripts": [
    {
      "matches": ["*://mail.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["*://mail.google.com/*"]
    }
  ]
}